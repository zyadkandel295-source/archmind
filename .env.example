# Shared
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_ACTIVITY_COLLECTION=site_activity

# API
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://archmind:archmind@localhost:5432/archmind
ARCHMIND_PLATFORM_STORE=postgres
ARCHMIND_RUN_MIGRATIONS=false
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=localhost
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=

# AI / RAG
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openrouter/auto
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1:free
OPENROUTER_CODING_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_VERIFIER_MODEL=openrouter/auto
ENABLE_ANSWER_VERIFICATION=true
VERIFY_MATH=true
VERIFY_CODE=true
VERIFY_RESEARCH=true

# Storage / billing / ops
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
SENTRY_DSN=

# Optional production integrations. Leave empty when disconnected; placeholder values are rejected operationally.
GMAIL_API_TOKEN=
GOOGLE_CALENDAR_API_TOKEN=
GOOGLE_SHEETS_API_TOKEN=
NOTION_INTEGRATION_TOKEN=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:4000/api/auth/notion/callback
TELEGRAM_BOT_TOKEN=
WEBHOOK_SIGNING_SECRET=

# Production hardening
TRUSTED_PROXY_COUNT=0
LOG_LEVEL=info
ARCHMIND_DATA_PATH=
DESKTOP_ARTIFACT_BUCKET=
DESKTOP_SIGNING_CERTIFICATE=
DESKTOP_SIGNING_PASSWORD=
UPDATE_SIGNING_PRIVATE_KEY=

