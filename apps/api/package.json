{
  "name": "@archmind/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "npm run build --prefix ../../packages/shared",
    "build": "tsc -p tsconfig.json",
    "dev": "cross-env NODE_OPTIONS=--use-system-ca tsx watch src/server.ts",
    "import:platform-json": "tsx src/tools/import-platform-json.ts",
    "start": "cross-env NODE_OPTIONS=--use-system-ca node dist/server.js",
    "test": "vitest run --pool=forks",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker": "cross-env NODE_OPTIONS=--use-system-ca tsx src/worker.ts"
  },
  "dependencies": {
    "@archmind/shared": "file:../../packages/shared",
    "@notionhq/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "isomorphic-dompurify": "^3.19.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "rate-limit-redis": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
